@{
    ViewBag.Title = "Admin Dashboard";
}

<!-- Bootstrap CDN (agar already layout me nahi hai to add karo) -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    body {
        background: linear-gradient(135deg, #667eea, #764ba2); 
        min-height: 100vh;
        font-family: 'Segoe UI', sans-serif;
    }

    .glass-card {
        background: linear-gradient( 135deg, rgba(255, 255, 255, 0.25), rgba(255, 255, 255, 0.05) );
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25);
        transition: 0.3s;
        color: #fff;
    }

        .glass-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.35);
        }

    .card h4 {
        font-size: 30px;
        font-weight: bold;
    }

    .card p {
        font-size: 16px;
        opacity: 0.9;
    }

    h2, h3 {
        color: #fff;
        font-weight: 600;
    }

    hr {
        border-color: rgba(255,255,255,0.3);
    }
</style>

<div class="container mt-4">

    <h2 class="mb-4">Admin Dashboard</h2>

    <!-- TOP CARDS -->
    <div class="row">

        <div class="col-md-3 mb-3">
            <div class="card glass-card">
                <div class="card-body">
                    <h4>@ViewBag.TotalUsers</h4>
                    <p>Total Users</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card glass-card">
                <div class="card-body">
                    <h4>@ViewBag.TotalServices</h4>
                    <p>Total Services</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card glass-card">
                <div class="card-body">
                    <h4>@ViewBag.TotalAppointments</h4>
                    <p>Total Appointments</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card glass-card">
                <div class="card-body">
                    <h4>@ViewBag.TodayAppointments</h4>
                    <p>Today's Appointments</p>
                </div>
            </div>
        </div>

    </div>

    <hr />

    <!-- STATUS CARDS -->
    <h3 class="mt-4 mb-3">Appointment Status</h3>

    <div class="row">

        <div class="col-md-4 mb-3">
            <div class="card glass-card">
                <div class="card-body">
                    <h4>@ViewBag.PendingCount</h4>
                    <p>Pending</p>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card glass-card">
                <div class="card-body">
                    <h4>@ViewBag.ApprovedCount</h4>
                    <p>Approved</p>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card glass-card">
                <div class="card-body">
                    <h4>@ViewBag.CompletedCount</h4>
                    <p>Completed</p>
                </div>
            </div>
        </div>

    </div>

</div>